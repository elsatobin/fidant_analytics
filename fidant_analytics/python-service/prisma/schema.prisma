datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-py"
}

model DailyUsageCache {
  id        Int      @id @default(autoincrement())
  userId    Int
  date      DateTime
  committed Int
  reserved  Int
  limit     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}